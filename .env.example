# IMPORTANT: This file is safe to commit. It contains examples only.
# Copy to .env and fill with real values. The .env file is untracked and must never be committed.

# PROVIDER
# purpose: Selects which OpenTofu provider wrapper directory Just will use.
# required: required
# expected format: literal string: hetzner or linode
# valid example: TF_VAR_cloud_provider=hetzner
# security note: not secret
TF_VAR_cloud_provider=hetzner

# HETZNER_TOKEN
# purpose: API token for Hetzner Cloud provider (used only when TF_VAR_cloud_provider=hetzner).
# required: required for hetzner, optional otherwise
# expected format: non-empty API token string
# valid example: HCLOUD_TOKEN=replace-with-real-token
# security note: secret, store only in untracked .env
HCLOUD_TOKEN=

# LINODE_TOKEN
# purpose: API token for Linode provider (used only when TF_VAR_cloud_provider=linode).
# required: required for linode, optional otherwise
# expected format: non-empty personal access token string
# valid example: LINODE_TOKEN=replace-with-real-token
# security note: secret, store only in untracked .env
LINODE_TOKEN=

# TF_VAR_server_location
# purpose: Datacenter/region code for VPS placement.
# required: required
# expected format: provider-specific location slug
# valid example: TF_VAR_server_location=nbg1 (Hetzner) or TF_VAR_server_location=us-east (Linode)
# security note: not secret
TF_VAR_server_location=nbg1

# TF_VAR_server_type
# purpose: Instance type/plan slug.
# required: required
# expected format: provider-specific plan string
# valid example: TF_VAR_server_type=cx22 (Hetzner) or TF_VAR_server_type=g6-nanode-1 (Linode)
# security note: not secret
TF_VAR_server_type=cx22

# TF_VAR_server_image
# purpose: Debian 12 image identifier.
# required: required
# expected format: provider-specific image label for Debian 13
# valid example: TF_VAR_server_image=debian13
# security note: not secret
TF_VAR_server_image=debian13

# TF_VAR_hostname
# purpose: Primary hostname assigned to the server.
# required: required
# expected format: RFC-1123 compatible hostname
# valid example: TF_VAR_hostname=hermes-prod-01
# security note: not secret
TF_VAR_hostname=hermes-prod-01

# TF_VAR_admin_username
# purpose: Non-root administrative Linux user created via cloud-init.
# required: required
# expected format: lowercase UNIX username
# valid example: TF_VAR_admin_username=opsadmin
# security note: not secret
TF_VAR_admin_username=opsadmin

# TF_VAR_admin_group
# purpose: SSH allow-group used by hardening scripts.
# required: optional
# expected format: existing or to-be-created UNIX group name
# valid example: TF_VAR_admin_group=sshadmins
# security note: not secret
TF_VAR_admin_group=sshadmins

# TF_VAR_admin_ssh_public_key
# purpose: SSH public key injected for admin login.
# required: required
# expected format: single-line OpenSSH public key
# valid example: TF_VAR_admin_ssh_public_key=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... user@laptop
# security note: public key is low sensitivity; still keep consistent with your identity policy
TF_VAR_admin_ssh_public_key=

# TF_VAR_allowed_tcp_ports
# purpose: Additional inbound TCP ports to allow beyond SSH (22).
# required: optional
# expected format: JSON-style list of integers
# valid example: TF_VAR_allowed_tcp_ports=[443,8443]
# security note: not secret but security-sensitive
TF_VAR_allowed_tcp_ports=[]

# TF_VAR_enable_ipv6
# purpose: Enables IPv6 networking where provider supports it.
# required: optional
# expected format: true or false
# valid example: TF_VAR_enable_ipv6=true
# security note: not secret
TF_VAR_enable_ipv6=true

# TF_VAR_tags
# purpose: Key/value metadata tags applied to VPS resources where supported.
# required: optional
# expected format: JSON-style map of string keys/values
# valid example: TF_VAR_tags={"env":"prod","owner":"personal"}
# security note: not secret
TF_VAR_tags={}

# BOOTSTRAP_SSH_PRIVATE_KEY_PATH
# purpose: Local private key path used by Just bootstrap/verify/logs over SSH.
# required: required
# expected format: absolute file path on local machine (tilde is expanded by Justfile, but absolute is preferred)
# valid example: BOOTSTRAP_SSH_PRIVATE_KEY_PATH=/home/user/.ssh/id_ed25519
# security note: secret file path; key material itself must stay outside repo
BOOTSTRAP_SSH_PRIVATE_KEY_PATH=/home/CHANGE_ME/.ssh/id_ed25519

# BOOTSTRAP_SSH_PORT
# purpose: SSH port used for bootstrap connection (must match hardened sshd config).
# required: optional
# expected format: integer TCP port
# valid example: BOOTSTRAP_SSH_PORT=22
# security note: not secret
BOOTSTRAP_SSH_PORT=22

# TF_VAR_hermes_model
# purpose: Hermes runtime model identifier consumed by service env file.
# required: optional
# expected format: provider/model string
# valid example: TF_VAR_hermes_model=anthropic/claude-sonnet-4
# security note: not secret
TF_VAR_hermes_model=gpt-5.4-mini

# TF_VAR_hermes_provider
# purpose: Hermes upstream provider selector.
# required: optional
# expected format: provider slug
# valid example: TF_VAR_hermes_provider=openrouter
# security note: not secret
TF_VAR_hermes_provider=openai-codex

# HERMES_AGENT_VERSION
# purpose: Pinned hermes-agent version installed by bootstrap/30-hermes.sh.
# required: required
# expected format: exact semantic version
# valid example: HERMES_AGENT_VERSION=0.10.0
# security note: not secret
HERMES_AGENT_VERSION=0.10.0

# HERMES_AGENT_RELEASE_TAG
# purpose: GitHub release tag used when PyPI install is unavailable for pinned version.
# required: required
# expected format: tag like vYYYY.M.D
# valid example: HERMES_AGENT_RELEASE_TAG=v2026.4.16
# security note: not secret
HERMES_AGENT_RELEASE_TAG=v2026.4.16

# HERMES_API_KEY
# purpose: API key consumed by Hermes runtime environment.
# required: required for selected provider
# expected format: non-empty API key string
# valid example: HERMES_API_KEY=replace-with-real-api-key
# security note: secret, never print or commit
HERMES_API_KEY=

# TELEGRAM_BOT_TOKEN
# purpose: Bot token for Telegram long-poll gateway.
# required: required
# expected format: <bot_id>:<token>
# valid example: TELEGRAM_BOT_TOKEN=123456789:AAExampleToken
# security note: secret, never print or commit
TELEGRAM_BOT_TOKEN=

# TELEGRAM_ALLOWLIST_IDS
# purpose: Comma-separated allowed Telegram numeric chat/user IDs.
# required: required
# expected format: comma-separated integers (no spaces)
# valid example: TELEGRAM_ALLOWLIST_IDS=123456789,-100987654321
# security note: security-critical access control list; keep in .env only
TELEGRAM_ALLOWLIST_IDS=

# TELEGRAM_POLL_TIMEOUT
# purpose: Long-poll timeout seconds for Telegram getUpdates.
# required: optional
# expected format: integer seconds (10-60 recommended)
# valid example: TELEGRAM_POLL_TIMEOUT=30
# security note: not secret
TELEGRAM_POLL_TIMEOUT=30
